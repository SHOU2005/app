generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String           @id @default(cuid())
  name               String
  phone              String           @unique
  email              String?          @unique
  password           String           @default("")
  avatar             String?
  isActive           Boolean          @default(true)
  fcmToken           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  captainReferralId  String?
  role               Role             @default(WORKER)
  bookingsAsEmployer Booking[]        @relation("EmployerBookings")
  captainProfile     CaptainProfile?
  employerProfile    EmployerProfile?
  notifications      Notification[]
  opsProfile         OpsProfile?
  ratingsGiven       Rating[]         @relation("RatingsGiven")
  workerProfile      WorkerProfile?

  @@index([phone])
  @@index([role])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model EmployerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  ownerName         String?
  companyName       String?
  businessType      String?
  address           String?
  city              String?
  logo              String?
  lat               Float?
  lng               Float?
  gstNumber         String?
  totalShifts       Int       @default(0)
  rating            Float     @default(0)
  captainReferralId String?
  verifiedByOpsAt   DateTime?
  user              User      @relation(fields: [userId], references: [id])
  shifts            Shift[]

  @@index([city])
  @@index([userId])
}

model WorkerProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  profilePhoto      String?
  aadhaarNumber     String?
  aadhaarFront      String?
  aadhaarBack       String?
  aadhaarVerified   Boolean        @default(false)
  videoVerified     Boolean        @default(false)
  skills            String[]
  city              String?
  lat               Float?
  lng               Float?
  hourlyRate        Float          @default(125)
  rating            Float          @default(0)
  totalShifts       Int            @default(0)
  totalEarnings     Float          @default(0)
  isAvailable       Boolean        @default(true)
  bio               String?
  captainReferralId String?
  kycStatus         KycStatus      @default(PENDING)
  milestoneLevel    Int            @default(0)
  availability      Availability[]
  bookings          Booking[]
  ratings           Rating[]       @relation("WorkerRatings")
  user              User           @relation(fields: [userId], references: [id])

  @@index([city])
  @@index([kycStatus])
  @@index([userId])
}

model Availability {
  id              String        @id @default(cuid())
  workerProfileId String
  date            DateTime
  startTime       String
  endTime         String
  isBooked        Boolean       @default(false)
  worker          WorkerProfile @relation(fields: [workerProfileId], references: [id])

  @@index([workerProfileId, date])
}

model Shift {
  id                String          @id @default(cuid())
  employerProfileId String
  title             String
  role              String
  description       String?
  address           String
  city              String
  lat               Float?
  lng               Float?
  date              DateTime
  startTime         String
  endTime           String
  duration          Float
  workersNeeded     Int             @default(1)
  hourlyRate        Float           @default(200)
  isUrgent          Boolean         @default(false)
  urgentFee         Float           @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  status            ShiftStatus     @default(OPEN)
  bookings          Booking[]
  employer          EmployerProfile @relation(fields: [employerProfileId], references: [id])

  @@index([city, date])
  @@index([lat, lng])
}

model Booking {
  id              String        @id @default(cuid())
  shiftId         String
  workerProfileId String
  employerId      String
  totalAmount     Float
  platformFee     Float
  workerEarning   Float
  paymentId       String?
  checkInTime     DateTime?
  checkOutTime    DateTime?
  notes           String?
  appliedAt       DateTime?     @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  employer        User          @relation("EmployerBookings", fields: [employerId], references: [id])
  shift           Shift         @relation(fields: [shiftId], references: [id])
  worker          WorkerProfile @relation(fields: [workerProfileId], references: [id])
  commission      Commission?
  payment         Payment?
  rating          Rating?

  @@index([shiftId])
  @@index([shiftId, status])
  @@index([workerProfileId])
  @@index([employerId])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  razorpayOrderId   String?
  razorpayPaymentId String?
  amount            Float
  currency          String        @default("INR")
  createdAt         DateTime      @default(now())
  status            PaymentStatus @default(PENDING)
  booking           Booking       @relation(fields: [bookingId], references: [id])
}

model Rating {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  workerProfileId String
  ratedById       String
  score           Int
  comment         String?
  createdAt       DateTime      @default(now())
  bookingRef      Booking       @relation(fields: [bookingId], references: [id])
  ratedBy         User          @relation("RatingsGiven", fields: [ratedById], references: [id])
  booking         WorkerProfile @relation("WorkerRatings", fields: [workerProfileId], references: [id])
}

model Complaint {
  id          String    @id @default(cuid())
  bookingId   String?
  reportedBy  String
  against     String
  type        String
  description String
  status      String    @default("OPEN")
  resolution  String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

model OtpLog {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model CaptainProfile {
  id            String              @id @default(cuid())
  userId        String              @unique
  referralCode  String              @unique
  territory     String?
  totalEarnings Float               @default(0)
  pendingPayout Float               @default(0)
  joinedAt      DateTime            @default(now())
  status        CaptainStatus       @default(PENDING)
  lat           Float?
  lng           Float?
  lastSeenAt    DateTime?
  attendances   CaptainAttendance[]
  user          User                @relation(fields: [userId], references: [id])
  tasks         CaptainTask[]
  commissions   Commission[]

  @@index([status])
  @@index([territory])
}

model Commission {
  id               String           @id @default(cuid())
  captainProfileId String
  bookingId        String           @unique
  amount           Float            @default(100)
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
  status           CommissionStatus @default(PENDING)
  booking          Booking          @relation(fields: [bookingId], references: [id])
  captain          CaptainProfile   @relation(fields: [captainProfileId], references: [id])

  @@index([captainProfileId, status])
}

model CaptainTask {
  id               String         @id @default(cuid())
  captainProfileId String
  assignedByUserId String
  title            String
  description      String?
  dueDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  status           TaskStatus     @default(OPEN)
  captain          CaptainProfile @relation(fields: [captainProfileId], references: [id])

  @@index([captainProfileId, status])
}

model CaptainAttendance {
  id               String         @id @default(cuid())
  captainProfileId String
  date             DateTime
  checkInTime      DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkOutTime     DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  captain          CaptainProfile @relation(fields: [captainProfileId], references: [id])

  @@index([captainProfileId, date])
}

model OpsProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  permissions String[]
  user        User     @relation(fields: [userId], references: [id])
}

model BroadcastLog {
  id           String   @id @default(cuid())
  sentByUserId String
  title        String
  body         String
  targetRole   String?
  targetCity   String?
  sentCount    Int      @default(0)
  createdAt    DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CaptainStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum Role {
  WORKER
  EMPLOYER
  CAPTAIN
  OPS
  ADMIN
}

enum ShiftStatus {
  OPEN
  SEARCHING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  OPEN
  COMPLETED
}
