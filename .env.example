# ── Database ──────────────────────────────────────────────────────────────────
# Same DATABASE_URL as your api.relayy.world Python backend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/switch_shift"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ── OTP / SMS — pick one provider ─────────────────────────────────────────────
# Priority: Fast2SMS → 2Factor → Twilio → console log (dev)

# Option A: Fast2SMS (recommended — cheap Indian OTP, no sender number needed)
# Get from https://www.fast2sms.com/dashboard/dev/api
FAST2SMS_API_KEY=""

# Option B: 2Factor
# Get from https://2factor.in/CP/
TWOFACTOR_API_KEY=""

# Option C: Twilio (international fallback)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+91xxxxxxxxxx"

# ── Firebase Phone Auth (hearus-4f2fe project) ────────────────────────────────
# Client-side: needed to initialize Firebase Phone Auth in the browser
NEXT_PUBLIC_FIREBASE_AUTH_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="hearus-4f2fe.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_AUTH_PROJECT_ID="hearus-4f2fe"

# Server-side: base64-encoded service account JSON (same as HEARUS_FIREBASE_CREDENTIALS_BASE64
# in your Python backend) — used to verify Firebase ID tokens securely
HEARUS_FIREBASE_CREDENTIALS_BASE64=""

# Legacy FCM HTTP API server key — from hearus-4f2fe Firebase Console → Project Settings → Cloud Messaging
FIREBASE_SERVER_KEY=""

# VAPID key for web push
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_SkZqvkCFHqldtp"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_SkZqvkCFHqldtp"

# ── Google Maps ───────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com — enable "Maps JavaScript API"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
